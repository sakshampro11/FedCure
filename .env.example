# ──────────────────────────────────────────────
# FedCure — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Backend ──
DATABASE_URL=sqlite:///./fedcure.db
JWT_SECRET=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── FL Clients (API keys from /api/hospitals/register) ──
HOSPITAL_1_API_KEY=
HOSPITAL_2_API_KEY=
HOSPITAL_3_API_KEY=
HOSPITAL_4_API_KEY=
